<?xml version="1.0" encoding="UTF-8"?>
<!--
    Base PHPUnit configuration — used by:
      composer test          (all suites)
      composer test-unit     (Unit suite only)
      composer test-feature  (Feature suite only)

    No <source> or <coverage> here — those live in phpunit.coverage.xml
    so that running tests without Xdebug/PCOV never emits a coverage
    driver warning (which would cause exit-code 1 and fail CI).

    To generate an HTML coverage report locally (requires Xdebug or PCOV):
      composer test-coverage
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         stopOnFailure="false">

    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

</phpunit>
